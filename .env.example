# Copy this to .env and fill in real values.
# .env is gitignored; .env.example is committed.

# ---- Polymarket (required for LIVE mode only; leave blank for PAPER) ----
POLYMARKET_PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY_HERE
POLYMARKET_FUNDER=0xYOUR_FUNDER_ADDRESS_HERE
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# ---- Telegram alerts (required; set these before running on AWS) ----
# Get TELEGRAM_BOT_TOKEN from @BotFather
# Get TELEGRAM_CHAT_ID from @userinfobot
TELEGRAM_BOT_TOKEN=0000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=0000000000
