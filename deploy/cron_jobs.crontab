# Polymarket weather alpha — paper mode cron jobs (KST)
# Installed by: deploy/ec2_setup.sh
# Inspect:      crontab -l
# Edit:         crontab -e
# Logs:         /home/ubuntu/polymarket/logs/

SHELL=/bin/bash
PATH=/home/ubuntu/polymarket/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
TZ=Asia/Seoul

# Full autotrade cycle every hour (settle -> analyze -> execute -> notify)
# Phase 1 paper: hourly is conservative. Bump to */30 once calibration matures.
0 * * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/polymarket-strat autotrade >> /home/ubuntu/polymarket/logs/autotrade.log 2>&1

# Apr 27 2026 — MTM-only price snapshot every 5 minutes. Independent of
# the hourly autotrade cycle (no settle/rebalance/analyze). Updates the
# market_prices table so the dashboard's unrealised-P&L panel reflects
# fresh CLOB prices between hourly ticks. ~18 orderbook fetches per run
# at current open-position count. The :02 minute offset stays clear of
# the :00 hourly autotrade tick.
2,7,12,17,22,27,32,37,42,47,52,57 * * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/polymarket-strat snap-mtm >> /home/ubuntu/polymarket/logs/snap_mtm.log 2>&1

# Daily calibration refresh at 04:00 KST (off-peak, after EU close)
0 4 * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/polymarket-strat weather-calibrate >> /home/ubuntu/polymarket/logs/calibrate.log 2>&1

# Daily DB backup at 04:30 KST, retain 14
30 4 * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/python scripts/backup_db.py --keep 14 >> /home/ubuntu/polymarket/logs/backup.log 2>&1

# Daily HTML report regeneration at 05:00 KST
0 5 * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/polymarket-strat report >> /home/ubuntu/polymarket/logs/report.log 2>&1

# Apr 24 2026 — accuracy-layer refresh jobs. Each runs nightly after
# calibration and uses the freshest available data:
#   fit_isotonic        : per-(city, lead) calibration curves from walk-forward CSV
#   fit_reliability     : per-city Brier + sample-count → position sizing multiplier
#   fit_bucket_blocklist: data-driven (city, lead, regime) auto-block from trade_history
# All three are idempotent and fail-safe (graceful fallback to identity /
# unblocked / multiplier=1.0 when input data is missing).
5 5 * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/python scripts/fit_isotonic.py >> /home/ubuntu/polymarket/logs/fit_isotonic.log 2>&1
10 5 * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/python scripts/fit_reliability.py >> /home/ubuntu/polymarket/logs/fit_reliability.log 2>&1
15 5 * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/python scripts/fit_bucket_blocklist.py >> /home/ubuntu/polymarket/logs/fit_bucket_blocklist.log 2>&1

# Apr 25 2026 — per-city ECE shrinkage refresh.
# Order matters: honest_ece.py must run BEFORE compute_per_city_ece (which
# reads its output). And compute_per_city_ece must run AFTER fit_reliability
# (which writes the base reliability.json that compute_per_city_ece extends).
# Time slots: 05:20 honest_ece (slow ~7min), 05:30 compute_per_city_ece (fast).
20 5 * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/python scripts/honest_ece.py --leads 24 --external-climatology data/weather/climatology.json >> /home/ubuntu/polymarket/logs/honest_ece.log 2>&1
30 5 * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/python scripts/compute_per_city_ece.py >> /home/ubuntu/polymarket/logs/compute_per_city_ece.log 2>&1

# Apr 26 2026 — fix #2: NO-side isotonic from real settled NO trades.
# Independent of fit_isotonic.py (which fits YES-side from synthetic walk-forward).
# Runs after compute_per_city_ece at 05:35 KST. Reads trade_history directly,
# so it always has the freshest data (no dependency on walk-forward CSVs).
35 5 * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/python scripts/fit_no_isotonic.py >> /home/ubuntu/polymarket/logs/fit_no_isotonic.log 2>&1

# May 3-5 2026 — AI strategy review automation (J-curve self-improving system).
#   Daily brief : 06:00 KST every day. Sonnet 4.5. ~$0.02/run = $0.60/month.
#                 5-message Telegram brief: HEADLINE / ATTRIBUTION / PATTERN
#                 WATCH / TODAY'S CALL / ANALYST'S VIEW. Plain text BLUF
#                 with visual hierarchy (emoji semantic anchors + ━ dividers).
#   Weekly review: Wed + Sun 09:00 KST. Opus. ~$0.25/run × 2/wk = $2/month.
#                  14-message DEPTH-MODE review with hypothesis DAG, full
#                  code excerpts, mathematical attribution, pre-mortem,
#                  counterfactual scenarios, calibration self-audit, and
#                  3-week strategic outlook. Auto-writes proposed R<n> rows
#                  to strategy_hypotheses (status='proposed') via embedded
#                  parse_review_to_db so the next cycle sees its own thinking.
#                  Saves full report to reports/strategy_reviews/.
#   Evaluator   : 05:50 KST every day. Closes the J-curve loop — finds
#                 shipped hypotheses past their 7d window, computes
#                 7d-pre vs 7d-post P&L delta, classifies verdict
#                 (win/partial/lose/inconclusive), updates
#                 claude_calibration.was_correct. Idempotent. Methodology
#                 is intentionally blunt (uncontrolled for regime shift /
#                 cross-rec interaction); it produces SIGNAL, not proof,
#                 which the next weekly review's Claude weighs explicitly.
# All three fail gracefully — Telegram error message rather than silent fail.
0 6 * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/python scripts/daily_brief.py >> /home/ubuntu/polymarket/logs/daily_brief.log 2>&1
0 9 * * 0,3 cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/python scripts/strategy_review.py >> /home/ubuntu/polymarket/logs/strategy_review.log 2>&1
50 5 * * * cd /home/ubuntu/polymarket && /home/ubuntu/polymarket/venv/bin/python scripts/evaluate_hypotheses.py >> /home/ubuntu/polymarket/logs/evaluate_hypotheses.log 2>&1
